# =============================================================================
# Variabili d'ambiente — copiare in .env.local e compilare i valori reali.
# Le `NEXT_PUBLIC_*` sono esposte al browser; tutte le altre sono server-only.
# =============================================================================

# -- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only. Necessaria per:
#  - /api/account/delete (cancellazione hard dell'account dell'utente)
#  - /api/admin/users/[id]/delete (cancellazione utenti da admin)
#  - webhook Stripe (creazione/aggiornamento ordini)
#  - reconciliation cash on delivery
# Supabase Dashboard → Settings → API → service_role key.
# NON commitarla. NON esporla nel client (mai NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL pubblico dell'app (usato in link email, redirect Stripe Checkout, ecc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Anthropic (AI vision) ---------------------------------------------------
# Usato da /api/vision/extract-product per la compilazione automatica dei
# campi prodotto via foto. https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# -- Stripe (pagamenti) ------------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret per /api/stripe/webhook (Dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect (onboarding seller) — opzionale in dev
STRIPE_CONNECT_CLIENT_ID=ca_...

# -- Resend (email transazionale) --------------------------------------------
# https://resend.com/api-keys — dominio verificato con DKIM/SPF/DMARC.
RESEND_API_KEY=re_...
RESEND_FROM="MyCity <no-reply@mycity.it>"
RESEND_REPLY_TO=support@mycity.it

# -- Cloudflare Turnstile (CAPTCHA) ------------------------------------------
# https://dash.cloudflare.com → Turnstile → site
# Senza queste chiavi il CAPTCHA è disabilitato (solo per dev locale).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# -- Fatturazione elettronica SDI --------------------------------------------
# Provider supportati: fattureincloud | aruba | mock (default mock per dev).
SDI_PROVIDER=fattureincloud
SDI_API_KEY=
SDI_COMPANY_ID=

# -- KYC provider (verifica documento + face match) --------------------------
# Provider supportati: onfido | jumio | veriff | mock (default mock).
KYC_PROVIDER=mock
KYC_API_KEY=

# -- Sentry (error tracking) — opzionale -------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
# Server-side only — usato da withSentryConfig per upload source maps in build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -- PostHog (analytics + session replay) — opzionale ------------------------
# https://eu.posthog.com → Project → Project Settings → API Keys
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# -- Google Analytics 4 — opzionale ------------------------------------------
# Se vuoto, GA non viene caricato. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -- Push notifications (VAPID) — opzionale ----------------------------------
# Genera con: npx web-push generate-vapid-keys
# Solo la public va esposta. Quella private resta server-side per firmare.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@mycity.it

# -- Cron secret (protezione endpoint /api/cron/*) ---------------------------
# Genera con: openssl rand -hex 32
# Il cron esterno (cron-job.org, Render cron) deve passarlo come
# Authorization: Bearer $CRON_SECRET
CRON_SECRET=

# -- Contact form ------------------------------------------------------------
# Email che riceve i messaggi inviati da /contact
SUPPORT_EMAIL=support@mycity.it

# -- WhatsApp Business (link contatti) — opzionale ---------------------------
# Numero internazionale senza + (es. 393331234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# -- Upstash Redis (rate limit production multi-instance) — opzionale --------
# Fallback automatico a in-memory se non configurato.
# https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
