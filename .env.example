NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only. Necessaria per:
#  - /api/account/delete (cancellazione hard dell'account dell'utente)
#  - /api/admin/users/[id]/delete (cancellazione utenti da admin)
# La trovi in Supabase Dashboard → Settings → API → service_role key.
# NON commitarla nel repo. NON esporla nel client (niente NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Server-side only. Usato da /api/vision/extract-product per la compilazione
# automatica dei campi prodotto via foto. Genera la chiave su
# https://console.anthropic.com/ -> API Keys.
ANTHROPIC_API_KEY=sk-ant-...
