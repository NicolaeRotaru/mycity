# ============================================================
#  quant-bot — variabili d'ambiente (copia in .env e compila)
#  NON committare mai il .env reale.
# ============================================================

# --- Sicurezza / modalita' ---
# DRY_RUN=true  -> PAPER trading (nessun ordine reale). Default sicuro.
# Passa a false SOLO dopo backtest + forward test su testnet.
DRY_RUN=true
USE_TESTNET=true

# --- Exchange ---
EXCHANGE_ID=bybit                 # bybit | binanceusdm
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
SYMBOL=BTC/USDT:USDT              # Bybit perp; Binance: BTC/USDT
MARGIN_MODE=isolated

# --- Capitale ---
INITIAL_CAPITAL=900

# --- Comportamento ---
STOP_ON_DAILY_TARGET=true         # ferma i nuovi trade una volta preso il +1% del giorno
ENFORCE_MARGIN_CAP=false          # attiva il tetto di MARGINE per trade (vedi config.py)

# --- Notifiche Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs
